<div class="contents">
  <h2>ユーザー編集</h2>
   <div class="shared_links">
    <button class="return_target">
      <span class="return_text">トップページへ戻る</span>
      <%= link_to image_tag('return.svg', width:"30",height:"30"), root_path, class: :return_btn %>
    </button>

   </div>
   <div class='user-form'>
    <%= form_with model: current_user, local: true do |f|%> 
      <div class='field'>
        <div class='field-label'>
          <%= f.label :ニックネーム%>
        </div>
        <div class='field-input'>
          <%= f.text_field :nickname, autofocus: true%>
        </div>
      </div>
      <div class='field'>
        <div class='field-label'>
          <%= f.label :メールアドレス%>
        </div>
        <div class='field-input'>
          <%= f.email_field :email%>
        </div>
      </div>
      <div class='field'>
        <div class='field-label'>
          <%= f.label :現在のパスワード %><br>
          <small>(変更する場合は入力してください)</small>
          <span id="togglePasswordLogin" class="eye-icon">👁</span>
        </div>
        <div class='field-input'>
          <%= f.password_field :current_password, autocomplete: "current-password" %>
        </div>
      </div>
      <div class='field'>
        <div class='field-label'>
          <%= f.label :新しいパスワード %>
          <span id="togglePasswordLogin" class="eye-icon">👁</span>
        </div>
        <div class='field-input'>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "6文字以上の半角英数字" %>
        </div>
      </div>
      <div class='field'>
        <div class='field-label'>
          <%= f.label :新しいパスワード（確認用）%>
          <span id="togglePasswordLogin" class="eye-icon">👁</span>
        </div>
        <div class='field-input'>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "6文字以上の半角英数字" %>
        </div>
      </div>
      <div class='actions'>
        <%= f.submit "更新", class: 'btn'%>
      </div>
    <% end %>
   </div>
</div>
